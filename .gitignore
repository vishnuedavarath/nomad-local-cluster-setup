# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Terraform lock file (can be committed for consistency, but often ignored)
# .terraform.lock.hcl

# Terraform directory (plugins, modules cache)
.terraform/

# Terraform plan files
*.tfplan
*.tfplan.*

# Terraform variable files (may contain secrets)
*.tfvars
*.tfvars.json
!example.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
*.swo

# Temporary files
/tmp/
*.tmp

#dex
*.dex